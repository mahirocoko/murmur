{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Murmur",
  "version": "0.1.0",
  "identifier": "app.mahiro.murmur",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Murmur",
        "width": 360,
        "height": 350,
        "resizable": false,
        "visible": true,
        "decorations": false,
        "transparent": true,
        "backgroundColor": "#00000000",
        "windowEffects": {
          "effects": [
            "hudWindow"
          ],
          "state": "followsWindowActiveState",
          "radius": 14
        }
      },
      {
        "label": "settings",
        "title": "Murmur Settings",
        "width": 760,
        "height": 560,
        "minWidth": 680,
        "minHeight": 460,
        "resizable": true,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "backgroundColor": "#00000000",
        "windowEffects": {
          "effects": [
            "hudWindow"
          ],
          "state": "followsWindowActiveState",
          "radius": 16
        }
      },
      {
        "label": "indicator",
        "title": "Murmur Indicator",
        "width": 430,
        "height": 124,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "visibleOnAllWorkspaces": true,
        "skipTaskbar": true,
        "focus": false,
        "focusable": false,
        "visible": false,
        "transparent": true,
        "backgroundColor": "#00000000"
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
