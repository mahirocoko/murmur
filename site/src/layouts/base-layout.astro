---
import '../styles/global.css';

type Props = {
  title?: string;
  description?: string;
  lang?: 'en' | 'th';
};

const {
  title = 'Murmur — local-first macOS dictation',
  description = 'Murmur is a small macOS dictation app powered by local whisper.cpp transcription.',
  lang = 'en',
} = Astro.props;

const siteUrl = Astro.site ? new URL(Astro.site) : Astro.url;
const sitePath = siteUrl.pathname.endsWith('/') ? siteUrl.pathname : `${siteUrl.pathname}/`;
const assetBasePath = import.meta.env.BASE_URL === '/' ? sitePath : import.meta.env.BASE_URL;
const ogImageUrl = new URL(`${assetBasePath}og-image.png`, siteUrl.origin).toString();
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="theme-color" content="#1c1a19" />
    <link rel="icon" type="image/png" href={`${import.meta.env.BASE_URL}murmur-logo-cute-borderless-trimmed.png`} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
