---
import '../styles/global.css';

type Props = {
  title?: string;
  description?: string;
  lang?: 'en' | 'th';
};

const {
  title = 'Murmur — local-first macOS dictation',
  description = 'Murmur is a small macOS dictation app powered by local whisper.cpp transcription.',
  lang = 'en',
} = Astro.props;
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="theme-color" content="#1c1a19" />
    <link rel="icon" type="image/png" href={`${import.meta.env.BASE_URL}murmur-logo-cute-borderless-trimmed.png`} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
