---
import { cva, type VariantProps } from 'class-variance-authority';
import { cn } from '../../lib/utils';

type Props = VariantProps<typeof buttonVariants> & {
  href?: string;
  class?: string;
  target?: string;
  rel?: string;
};

const buttonVariants = cva(
  'inline-flex items-center justify-center gap-2 rounded-md text-sm font-semibold transition-colors duration-150 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary disabled:pointer-events-none disabled:opacity-50',
  {
    variants: {
      variant: {
        default: 'bg-primary text-primary-foreground hover:bg-[#f09a63]',
        secondary: 'border border-border bg-secondary text-secondary-foreground hover:bg-[#35312e]',
        ghost: 'text-muted hover:bg-secondary hover:text-foreground',
      },
      size: {
        default: 'h-10 px-4',
        sm: 'h-9 px-3',
        lg: 'h-11 px-5',
      },
    },
    defaultVariants: {
      variant: 'default',
      size: 'default',
    },
  },
);

const { href, variant, size, class: className, target, rel } = Astro.props;
const classes = cn(buttonVariants({ variant, size }), className);
const safeRel = target === '_blank' ? rel ?? 'noreferrer' : rel;
---
{href ? (
  <a href={href} target={target} rel={safeRel} class={classes}><slot /></a>
) : (
  <button class={classes}><slot /></button>
)}
